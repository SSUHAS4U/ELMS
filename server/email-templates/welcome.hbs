<div style="font-family:'Segoe UI',sans-serif;max-width:480px;margin:0 auto;padding:32px;background:#0A0A0B;border-radius:12px;border:1px solid #2A2A35;">
  <div style="text-align:center;margin-bottom:24px;">
    <div style="display:inline-block;width:40px;height:40px;background:#00FF87;border-radius:8px;"></div>
    <h1 style="color:#F0F0F5;font-size:22px;margin:16px 0 4px;">Welcome to Obsidian ELMS</h1>
  </div>
  <div style="background:#111114;border:1px solid #2A2A35;border-radius:8px;padding:24px;margin:24px 0;">
    <p style="color:#F0F0F5;font-size:15px;margin:0 0 16px;">Hi <strong>{{name}}</strong>,</p>
    <p style="color:#8888A0;font-size:14px;margin:0 0 16px;">Your account has been created. Here are your credentials:</p>
    <table style="width:100%;border-collapse:collapse;">
      <tr><td style="color:#8888A0;padding:6px 0;font-size:13px;">Email</td><td style="color:#F0F0F5;padding:6px 0;font-size:13px;font-weight:600;">{{email}}</td></tr>
      <tr><td style="color:#8888A0;padding:6px 0;font-size:13px;">Password</td><td style="color:#00FF87;padding:6px 0;font-size:13px;font-weight:600;font-family:monospace;">{{password}}</td></tr>
      <tr><td style="color:#8888A0;padding:6px 0;font-size:13px;">Role</td><td style="color:#F0F0F5;padding:6px 0;font-size:13px;font-weight:600;text-transform:uppercase;">{{role}}</td></tr>
    </table>
  </div>
  <p style="color:#555;font-size:12px;text-align:center;">Please change your password after first login.</p>
</div>
