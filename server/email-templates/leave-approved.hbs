<div style="font-family:'Segoe UI',sans-serif;max-width:480px;margin:0 auto;padding:32px;background:#0A0A0B;border-radius:12px;border:1px solid #2A2A35;">
  <div style="text-align:center;margin-bottom:24px;">
    <div style="display:inline-block;width:40px;height:40px;background:#00FF87;border-radius:8px;"></div>
    <h1 style="color:#00C96B;font-size:22px;margin:16px 0 4px;">Leave Approved ✓</h1>
  </div>
  <div style="background:#111114;border:1px solid #2A2A35;border-radius:8px;padding:24px;margin:24px 0;">
    <p style="color:#F0F0F5;font-size:14px;margin:0 0 8px;">Your leave for <strong style="color:#00FF87;">{{dates}}</strong> has been approved.</p>
    {{#if note}}<p style="color:#8888A0;font-size:13px;margin:12px 0 0;">Note: {{note}}</p>{{/if}}
  </div>
</div>
